{
  "schema_version": 1,
  "contract_name": "claude-current",
  "provider": "claude",
  "cli_version_range": {
    "minimum": "1.0.0",
    "maximum_exclusive": "3.0.0"
  },
  "hook_events": [
    "SessionStart",
    "PreToolUse",
    "PostToolUse",
    "SubagentStart",
    "SubagentStop"
  ],
  "tools": [
    {
      "canonical_name": "spawn",
      "names": ["Task", "claude.Task"],
      "input_schema": {
        "type": "object",
        "required": ["subagent_type", "description", "prompt"],
        "properties": {
          "subagent_type": {"type": "string", "minLength": 1},
          "model": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "prompt": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  ],
  "model_selector_path": "model",
  "correlation_fields": {
    "run_id": ["session_id"],
    "caller_id": ["agent_id"],
    "child_id": ["agent_id"],
    "task_id": ["description"],
    "lifecycle_id": ["tool_use_id", "agent_id"]
  },
  "usage_fields": [
    "input_tokens",
    "cache_read_input_tokens",
    "cache_creation_input_tokens",
    "output_tokens"
  ],
  "decision_response_schema": {
    "type": "object",
    "required": ["hookSpecificOutput"]
  },
  "trust_visibility": true,
  "can_block": true
}
